# 服务端口
PORT=3459

# 公网 base URL（用于 OAuth callback 与前端展示）
PUBLIC_BASE_URL=https://www.html.living/reimbursement

# Google OAuth 凭证（在 Google Cloud Console 创建）
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret
# 回调 URL 必须与 Google Cloud Console 配置一致
GOOGLE_CALLBACK_URL=https://www.html.living/reimbursement/auth/google/callback

# 仅允许此域名的 Google 账号登录（留空则允许所有）
ALLOWED_DOMAIN=feedmob.com

# Session secret（随机长字符串）
SESSION_SECRET=change-me-to-a-random-string

# API Token 派生密钥（用于 hash 用户 ID 生成稳定 Token，重置 Token 时换此值）
TOKEN_SECRET=change-me-to-another-random-string

# 火山 Ark OCR API Key
ARK_API_KEY=
ARK_OCR_MODEL=doubao-1.5-vision-pro-250328

# 数据持久化文件路径
DATA_FILE=./data/store.json
UPLOAD_DIR=./uploads

# Cloudflare R2 存储（发票文件）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=html-screenshots
R2_PUBLIC_URL=https://pub-2ed43ebd6e6c47978b6fd3cb46b4c1c9.r2.dev
